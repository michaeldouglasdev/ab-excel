# CleverTap API credentials
# Get these from: CleverTap Dashboard > Settings > API Credentials
CLEVERTAP_ACCOUNT_ID=your_account_id
CLEVERTAP_PASSCODE=your_passcode

# Path to Excel file (or pass as argument)
EXCEL_FILE_PATH=./profiles.xlsx

# --- populate-profiles: filtro por evento ---
# Nome do evento (ex: App Launched, Charged)
CLEVERTAP_EVENT_NAME=App Launched
# Período em YYYYMMDD (ex: 20240101 a 20241231)
CLEVERTAP_FROM=20240101
CLEVERTAP_TO=20241231
